#~ "png ئاتتا ساقلايدۇ"

#~ msgid ""
#~ "Takes a screenshot of each widget and saves it the working directory as "
#~ "<pluginname>.png"
#~ msgstr ""
#~ "بۇ widget نىڭ ھەر بىر ئېكران كۆرۈنۈشىنى تۇتۇپ، خىزمەت مۇندەرىجىسىدە "
#~ "<pluginname>.png ئاتتا ساقلايدۇ"

#~ msgid "Desktop SVG theme to use"
#~ msgstr "ئىشلىتىدىغان ئۈستەلئۈستى SVG ئۆرنىكى"

#~ msgid ""
#~ "Name of the wallpaper plugin. Requires a containment plugin to be "
#~ "specified."
#~ msgstr ""
#~ "تام قەغەز قىستۇرمىسىنىڭ ئاتى. چوقۇم قاچا قىستۇرمىدىن بىرنى بەلگىلەش زۆرۈر."

#~ msgid ""
#~ "Name of applet to view; may refer to the plugin name or be a path "
#~ "(absolute or relative) to a package. If not provided, then an attempt is "
#~ "made to load a package from the current directory."
#~ msgstr ""
#~ "كۆرىدىغان قوللانچاق ئاتى؛ بەلگىلەنگىنى قىستۇرما ئاتى ياكى بوغچا يولى "
#~ "(مۇتلەق ياكى نىسپىي). ئەگەر تەمىنلەنمىسە، ئۇنداقتا نۆۋەتتىكى مۇندەرىدە "
#~ "بوغچىنى يۈكلەشنى سىنايدۇ."

#~ msgid "Optional arguments of the applet to add"
#~ msgstr "قوشىدىغان قوللانچاقنىڭ تاللاشچان ئۆزگەرگۈچىلىرى"

#~ msgid "List zeroconf announced remote widgets"
#~ msgstr "zeroconf مۇلازىمىتى بايقىغان يىراقتىكى widget تىزىمىنى كۆرسىتىدۇ"
